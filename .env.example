# Copy to .env and fill in. Never commit the real .env.

# The Google Sheet that acts as the database (the ID from its URL)
SHEET_ID=1ARYg5u5gVMbL1jeIotTJGcrWuZ1n4oRHgxBYVIyP2OQ

# The worksheet/tab name inside that spreadsheet that holds the data
WORKSHEET_NAME=Sheet1

# The Google Drive folder for this project (used for the version text file)
DRIVE_FOLDER_ID=1lMSKUDMbu8fE3n0fd0mk8mVLz1yy37uk

# Service account credentials. Provide ONE of these:
#   - GOOGLE_SERVICE_ACCOUNT_JSON : the full JSON key contents (best for Render)
#   - GOOGLE_APPLICATION_CREDENTIALS : a path to a service_account.json file (local dev)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=service_account.json
